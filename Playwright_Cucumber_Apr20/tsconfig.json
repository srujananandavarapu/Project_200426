{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "bundler",

    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],
    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}

